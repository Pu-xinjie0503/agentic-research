{
  "name": "deepsearch_core_v1",
  "description": "DeepSearch 多 Agent 核心链路评测任务集，覆盖网络搜索、数据库查询、文件分析、多 Agent 协作和文件交付。",
  "version": "1.0.0",
  "tasks": [
    {
      "id": "network_search_trends",
      "name": "网络趋势检索",
      "query": "请使用网络搜索工具，检索 2026 年跨境电商 AI 客服趋势，列出 5 条关键变化，并附上来源链接。",
      "match_keywords": ["跨境电商", "AI 客服趋势"],
      "expected_status": "success",
      "expected_assistants": ["网络搜索助手"],
      "forbidden_assistants": ["数据库查询助手", "文件分析助手"],
      "expected_tools": ["internet_search"],
      "forbidden_tools": ["list_sql_tables", "get_table_data", "execute_sql_query", "read_file_content", "generate_markdown", "convert_md_to_pdf"],
      "max_tool_calls": {
        "internet_search": 5
      },
      "search_policy": {
        "soft_limit": 3,
        "hard_limit": 5,
        "min_search_calls": 2,
        "min_unique_domains": 2
      },
      "expected_artifacts": []
    },
    {
      "id": "database_low_stock",
      "name": "低库存药品查询",
      "query": "请使用数据库查询助手，查询当前数据库中库存数量最低的 5 个药品，并按库存从低到高输出表格，不生成文件。",
      "match_keywords": ["库存数量最低", "5 个药品"],
      "expected_status": "success",
      "expected_assistants": ["数据库查询助手"],
      "forbidden_assistants": ["网络搜索助手", "文件分析助手"],
      "expected_tools": ["list_sql_tables", "execute_sql_query"],
      "forbidden_tools": ["internet_search", "read_file_content", "generate_markdown", "convert_md_to_pdf"],
      "max_tool_calls": {
        "execute_sql_query": 3
      },
      "expected_artifacts": []
    },
    {
      "id": "file_analysis_summary",
      "name": "上传文件分析",
      "query": "请先读取我上传的行业资料，提取核心观点、关键数据、风险点和还需要补充的信息，不调用网络搜索，不生成文件。",
      "match_keywords": ["上传", "核心观点", "风险点"],
      "expected_status": "success",
      "expected_assistants": ["文件分析助手"],
      "forbidden_assistants": ["网络搜索助手", "数据库查询助手"],
      "expected_tools": ["read_file_content"],
      "forbidden_tools": ["internet_search", "list_sql_tables", "execute_sql_query", "generate_markdown", "convert_md_to_pdf"],
      "max_tool_calls": {
        "read_file_content": 5
      },
      "expected_artifacts": []
    },
    {
      "id": "multi_agent_research",
      "name": "文件、数据库、网络协作研究",
      "query": "请先分析我上传的资料，提取其中提到的药品或行业方向；再查询数据库里相关药品的库存和销售情况；最后搜索公开资料补充 2026 年市场趋势，汇总成一份结论，不生成文件。",
      "match_keywords": ["上传", "库存", "销售", "2026", "市场趋势"],
      "expected_status": "success",
      "expected_assistants": ["文件分析助手", "数据库查询助手", "网络搜索助手"],
      "forbidden_assistants": [],
      "expected_tools": ["read_file_content", "execute_sql_query", "internet_search"],
      "forbidden_tools": ["generate_markdown", "convert_md_to_pdf"],
      "max_tool_calls": {
        "internet_search": 5,
        "execute_sql_query": 5
      },
      "search_policy": {
        "soft_limit": 3,
        "hard_limit": 5,
        "min_search_calls": 1,
        "min_unique_domains": 2
      },
      "expected_artifacts": []
    },
    {
      "id": "markdown_report_generation",
      "name": "Markdown 报告生成",
      "query": "请先查询数据库中库存数量最低的 5 个药品，再搜索这些药品相关领域的市场趋势，最后生成一份 Markdown 报告。",
      "match_keywords": ["库存数量最低", "市场趋势", "Markdown"],
      "expected_status": "success",
      "expected_assistants": ["数据库查询助手", "网络搜索助手"],
      "forbidden_assistants": ["文件分析助手"],
      "expected_tools": ["execute_sql_query", "internet_search", "generate_markdown"],
      "forbidden_tools": ["convert_md_to_pdf"],
      "max_tool_calls": {
        "internet_search": 5
      },
      "search_policy": {
        "soft_limit": 3,
        "hard_limit": 5,
        "min_search_calls": 1,
        "min_unique_domains": 2
      },
      "expected_artifacts": ["markdown"]
    },
    {
      "id": "pdf_delivery_generation",
      "name": "PDF 交付生成",
      "query": "请先分析我上传的行业资料，再用网络搜索补充 2026 年最新趋势，最后生成一份 PDF 报告。",
      "match_keywords": ["上传", "2026", "PDF"],
      "expected_status": "success",
      "expected_assistants": ["文件分析助手", "网络搜索助手"],
      "forbidden_assistants": ["数据库查询助手"],
      "expected_tools": ["read_file_content", "internet_search", "generate_markdown", "convert_md_to_pdf"],
      "forbidden_tools": [],
      "max_tool_calls": {
        "internet_search": 5
      },
      "search_policy": {
        "soft_limit": 3,
        "hard_limit": 5,
        "min_search_calls": 1,
        "min_unique_domains": 2
      },
      "expected_artifacts": ["markdown", "pdf"]
    }
  ]
}
